FROM node:24

ARG GO_VERSION=1.25.7

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    corkscrew \
    procps \
    sudo \
    jq \
    ripgrep \
    docker.io \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Go toolchain
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" -o /tmp/go.tgz && \
    rm -rf /usr/local/go && \
    tar -C /usr/local -xzf /tmp/go.tgz && \
    rm -f /tmp/go.tgz && \
    ln -s /usr/local/go/bin/go /usr/local/bin/go && \
    ln -s /usr/local/go/bin/gofmt /usr/local/bin/gofmt

# Ensure default node user has access to /usr/local/share
RUN mkdir -p /usr/local/share/npm-global && \
    chown -R node:node /usr/local/share

# Create workspace and config directories with proper permissions
RUN mkdir -p /workspace /home/node/.claude /home/node/.local/bin /home/node/.local/share && \
    chown -R node:node /workspace /home/node/.claude /home/node/.local

WORKDIR /workspace

# Switch to non-root user
USER node

# Set up npm global prefix for non-root installs
ENV TERM=xterm-256color
ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global
ENV PATH=$PATH:/usr/local/share/npm-global/bin:/home/node/.local/bin

# Install Claude Code CLI via native installer
RUN curl -fsSL https://claude.ai/install.sh | bash

# Install Codex CLI
RUN npm i -g @openai/codex

CMD ["claude"]
